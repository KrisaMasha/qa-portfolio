{
  "info": {
    "name": "CenterFish.ru - API Tests",
    "description": "Postman collection for testing CenterFish.ru website",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Site Availability",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://centerfish.ru",
          "protocol": "https",
          "host": ["centerfish", "ru"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Homepage Content Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://centerfish.ru/",
          "protocol": "https",
          "host": ["centerfish", "ru"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Body contains company name\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Рыболовный центр\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Search Functionality",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://centerfish.ru/search?q=катушка",
          "protocol": "https",
          "host": ["centerfish", "ru"],
          "path": ["search"],
          "query": [
            {
              "key": "q",
              "value": "катушка"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "404 Page Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://centerfish.ru/nonexistent-page-test-12345",
          "protocol": "https",
          "host": ["centerfish", "ru"],
          "path": ["nonexistent-page-test-12345"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response is 404 or custom page\", function () {",
              "    pm.expect([404, 200]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "HTTPS Redirect Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://centerfish.ru",
          "protocol": "http",
          "host": ["centerfish", "ru"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"HTTPS is enforced\", function () {",
              "    if (pm.response.code === 301 || pm.response.code === 302) {",
              "        pm.expect(pm.response.headers.get('Location')).to.include('https://');",
              "    }",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
